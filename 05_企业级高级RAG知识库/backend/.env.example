# LLM
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=enterprise_knowledge

# Elasticsearch
ES_HOST=http://localhost:9200
ES_INDEX=enterprise_knowledge

# Embedding
EMBEDDING_MODEL_PATH=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSION=1024

# Reranker (Local Model)
RERANKER_MODEL_PATH=D:\Codex-project\models\modelscope_cache\BAAI\bge-reranker-large
RERANKER_THRESHOLD=0.6

# RAG Config
TOP_K=3
BM25_WEIGHT=0.4
VECTOR_WEIGHT=0.6
RRF_K=60
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# LangSmith (fill in your key later)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=enterprise-rag

# API
API_PORT=8083
